---
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">ZENOTME</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">About</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
		</div>
		<div class="social-links">
			<a
				href="https://x.com/ze_notme"
				target="_blank"
				rel="noopener noreferrer"
				aria-label="X / Twitter"
				title="X / Twitter"
			>
				<svg viewBox="0 0 24 24" aria-hidden="true">
					<path
						d="M22 4.01c-1 .49 -1.98 .689 -3 .99c-1.121 -1.265 -2.783 -1.335 -4.38 -.737s-2.643 2.06 -2.62 3.737v1c-3.245 .083 -6.135 -1.395 -8 -4c0 0 -4.182 7.433 4 11c-1.872 1.247 -3.739 2.088 -6 2c3.308 1.803 6.913 2.423 10.034 1.517c3.58 -1.04 6.522 -3.723 7.651 -7.742a13.84 13.84 0 0 0 .497 -3.753c0 -.249 1.51 -2.772 1.818 -4.013l0 .001"
					></path>
				</svg>
			</a>
			<a
				href="https://github.com/ZENOTME"
				target="_blank"
				rel="noopener noreferrer"
				aria-label="GitHub"
				title="GitHub"
			>
				<svg viewBox="0 0 24 24" aria-hidden="true">
					<path
						d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5"
					></path>
				</svg>
			</a>
			<a
				href="https://www.linkedin.com/in/zejiong-dong-428798268/"
				target="_blank"
				rel="noopener noreferrer"
				aria-label="LinkedIn"
				title="LinkedIn"
			>
				<svg viewBox="0 0 24 24" aria-hidden="true">
					<path d="M8 11v5" />
					<path d="M8 8v.01" />
					<path d="M12 16v-5" />
					<path d="M16 16v-3a2 2 0 1 0 -4 0" />
					<path d="M3 7a4 4 0 0 1 4 -4h10a4 4 0 0 1 4 4v10a4 4 0 0 1 -4 4h-10a4 4 0 0 1 -4 -4l0 -10" />
				</svg>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0 0 0.5rem;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		display: flex;
		margin: 0;
		font-size: 1.45rem;
		transform: translateX(-1.5rem);
	}

	h2 a,
	h2 a.active {
		display: flex;
		text-decoration: none;
		padding-left: 0;
	}
	nav {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
	}
	nav a {
		padding: 1rem 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links,
	.social-links a {
		display: flex;
	}
	.social-links :global(svg) {
		width: 21px;
		height: 21px;
		fill: none;
		stroke: currentColor;
		stroke-width: 1.75;
		stroke-linecap: round;
		stroke-linejoin: round;
	}
	@media (max-width: 720px) {
		header {
			padding: 0 1rem;
		}
		nav {
			display: grid;
			grid-template-columns: 1fr;
		}
		h2 {
			transform: none;
		}
		.internal-links {
			justify-self: start;
		}
		h2 a {
			padding: 0.6em 0 0.2em;
		}
		nav a {
			padding: 0.65em 0.35em;
		}
		.social-links {
			display: none;
		}
	}
</style>
