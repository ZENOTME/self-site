---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { getCollection } from "astro:content";
import {
    getAllPublishedNotionBlogItem,
    databaseId_tech,
    databaseId_life,
} from "../notion";
import FormattedDate from "../components/FormattedDate.astro";

const { tag } = Astro.params;

let posts = (await getCollection("blog")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

let [notion_posts, notion_posts_life] = await Promise.all([
    getAllPublishedNotionBlogItem(databaseId_tech),
    getAllPublishedNotionBlogItem(databaseId_life),
]);

if (tag) {
    posts = posts.filter((x) =>
        x.data.tags?.map((t) => t.toLowerCase()).includes(tag),
    );
    notion_posts = notion_posts.filter((x) =>
        x.tags?.map((t) => t.toLowerCase()).includes(tag),
    );
    notion_posts_life = notion_posts_life.filter((x) =>
        x.tags?.map((t) => t.toLowerCase()).includes(tag),
    );
}
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
        <style>
            ul {
                list-style-type: none;
                padding: unset;
            }
            main {
                margin-top: 1rem;
            }
            ul li {
                display: flex;
                margin-bottom: 0.45rem;
            }
            ul li :global(time) {
                flex: 0 0 130px;
                /* font-style: italic; */
                color: #595959;
            }
        </style>
    </head>
    <body>
        <Header />
        {tag && <h2>{tag}</h2>}
        <main>
            <section>
                <ul>
                    {
                        notion_posts.map((post) => (
                            <li>
                                <FormattedDate date={post.pubDate} />
                                <a href={`/notion_blog/${post.page_id}/`}>
                                    {post.title}
                                </a>
                            </li>
                        ))
                    }
                    {
                        posts.map((post) => (
                            <li>
                                <FormattedDate date={post.data.pubDate} />
                                <a href={`/blog/${post.slug}/`}>
                                    {post.data.title}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </section>
            <section>
                {
                    notion_posts_life.length > 0 && <>
                        <h4>Blog for life</h4>
                        <ul>
                            {
                                notion_posts_life.map((post) => (
                                    <li>
                                        <FormattedDate date={post.pubDate} />
                                        <a href={`/notion_blog/${post.page_id}/`}>
                                            {post.title}
                                        </a>
                                    </li>
                                ))
                            }
                        </ul>
                    </>
                }
            </section>
        </main>
    </body>
</html>
